{
  "name": "bglaundry-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "BG Laundry & Dry Cleaning Monorepo Workspace",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
